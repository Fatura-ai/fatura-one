generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  role      String   @default("CREATOR")
  createdAt DateTime @default(now())

  plan                 String?
  subscriptionStatus   String   @default("NONE")
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?

  decisions       Decision[] @relation("CreatedDecisions")
  lockedDecisions Decision[] @relation("LockedDecisions")
  approvals       Approval[] @relation("UserApprovals")
  invoices        Invoice[]
}

model Decision {
  id                 String   @id @default(uuid())
  decisionNumber     Int
  body               String
  decisionType       String
  scope              String
  createdByRole      String
  createdByIdentifier String

  title       String
  content     String
  titleEn     String?
  contentEn   String?

  status      String @default("DRAFT")

  createdAt   DateTime @default(now())
  submittedAt DateTime?
  approvedAt  DateTime?
  lockedAt    DateTime?

  createdById String
  lockedById  String?

  createdBy   User     @relation("CreatedDecisions", fields: [createdById], references: [id])
  lockedBy    User?    @relation("LockedDecisions", fields: [lockedById], references: [id])

  approvals   Approval[]
  proof       Proof?
}

model Approval {
  id         Int      @id @default(autoincrement())
  decisionId String
  approverId String

  role       String
  approvedAt DateTime @default(now())

  decision   Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  approver   User     @relation("UserApprovals", fields: [approverId], references: [id])

  @@index([decisionId])
}

model Proof {
  decisionId       String   @id
  contentHash      String
  verificationHash String
  createdAt        DateTime @default(now())

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  userId         String
  customerName   String
  customerPhone  String?
  customerEmail  String?
  currency       String        @default("IQD")
  bankName       String?
  bankAccount    String?
  bankAccountName String?
  total          Float
  status         String        @default("DRAFT")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  price       Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}